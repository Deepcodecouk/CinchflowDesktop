{
  "name": "cinchflow",
  "productName": "CinchFlow",
  "version": "1.6.0",
  "description": "Personal finance budgeting and cashflow forecasting desktop application",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:next": "node scripts/prepare-make-version.cjs && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test:cashflow": "tsc -p tsconfig.cashflow-tests.json && node --test .tmp-tests/renderer/features/cashflow/lib/*.test.js",
    "test:dashboard": "tsc -p tsconfig.dashboard-tests.json && node --test .tmp-tests/main/services/*.test.js",
    "test:register": "tsc -p tsconfig.register-tests.json && node --test .tmp-tests/renderer/features/register/lib/*.test.js"
  },
  "keywords": [],
  "author": "CinchFlow Contributors",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "40.6.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.5.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.576.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  }
}
